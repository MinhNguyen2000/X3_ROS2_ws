<?xml version = "1.0"?>
<robot name = "agent" xmlns:xacro = "http://www.ros.org/wiki/xacro">

    <!-- ========== ARGUMENTS & PARAMETERS ========== -->
    <xacro:arg name = "agent_name" default = "agent"/>
    <xacro:arg name = "use_ros_control" default = "false"/>
    <xacro:property name = "prefix" value = "$(arg agent_name)"/>
    <xacro:property name = "wheel_effort" value = "1.0"/>
    <!-- TODO - also change this in the controllers YAML file -->
    <xacro:property name = "wheel_max_vel" value = "50.0"/>
    
    <!-- ========== COMMON MACROS ========== -->
    <xacro:macro name="common_link" params="prefix name material *origin collision_shape collision_size collision_xyz:='0 0 0'">
        <link name="${prefix}_${name}">
            <visual>
                <geometry>
                    <mesh filename="package://x3_description/meshes/${name}.STL"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <material name="${material}"/>
            </visual>
            <collision>
                <geometry>
                    <xacro:if value="${collision_shape == 'box'}">
                        <box size="${collision_size}"/>
                    </xacro:if>
                    <xacro:if value="${collision_shape == 'cylinder'}">
                        <cylinder radius="${collision_size.split()[0]}" length="${collision_size.split()[1]}"/>
                    </xacro:if>
                </geometry>
                <origin xyz="${collision_xyz}" rpy="0 0 0"/>
            </collision>
            <xacro:insert_block name="origin"/>
        </link>
    </xacro:macro>
    <xacro:macro name="continuous_joint" params="prefix name parent child xyz rpy axis">
        <joint name="${prefix}_${name}" type="continuous">
            <parent link="${prefix}_${parent}"/>
            <child link="${prefix}_${child}"/>
            <origin xyz="${xyz}" rpy="${rpy}"/>
            <axis xyz="${axis}"/>
            <limit effort="${wheel_effort}" velocity="${wheel_max_vel}"/>
            <dynamics friction="1E-04"/>
        </joint>
    </xacro:macro>
    <xacro:macro name="fixed_joint" params="prefix name parent child xyz rpy">
        <joint name="${prefix}_${name}" type="fixed">
            <parent link="${prefix}_${parent}"/>
            <child link="${prefix}_${child}"/>
            <origin xyz="${xyz}" rpy="${rpy}"/>
        </joint>
    </xacro:macro>

    <xacro:macro name = "cylinder_inertia" params = "mass radius length">
        <inertia
            ixx = "${mass * (3 * radius**2 + length**2) / 12}"
            ixy = "0"
            ixz = "0"
            iyy = "${mass * (3 * radius**2 + length**2) / 12}"
            iyz = "0"
            izz = "${mass * radius**2 / 12}"
        />
    </xacro:macro>

    <!-- ========== Includes ========== -->
    <xacro:include filename = "x3_body.xacro"/>
    <xacro:include filename = "x3_sensors.xacro"/>
    <xacro:include filename = "x3_gazebo_properties.xacro"/>

    <!-- if using ros2_control -->
    <xacro:if value = "$(arg use_ros_control)">
        <xacro:include filename = "x3_ros_control.xacro"/>
    </xacro:if>

    <!-- if using gazebo control -->
    <xacro:unless value = "$(arg use_ros_control)">
        <xacro:include filename = "x3_gazebo_control.xacro"/>
    </xacro:unless>

</robot>